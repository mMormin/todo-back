# ==============================================================================
# DJANGO
# ==============================================================================

# Django secret key - generate a new one for production:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-here-change-this

# Settings module to load
# In production, set to: todo.core.settings.production
DJANGO_SETTINGS_MODULE=todo.core.settings.development

# ==============================================================================
# DOMAINS (production only)
# ==============================================================================

# Allowed hosts, comma-separated
ALLOWED_HOSTS=my-api.onrender.com,api.mydomain.com

# Frontend origins allowed by CORS, comma-separated
CORS_ALLOWED_ORIGINS=https://my-frontend.vercel.app,https://mydomain.com

# ==============================================================================
# DATABASE (production only)
# ==============================================================================

# PostgreSQL connection URL (provided by Render, Railway, Supabase, etc.)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://user:password@host:5432/dbname

# ==============================================================================
# SUPERUSER (production only)
# ==============================================================================

# Automatically created on deploy if not already existing
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-password

# ==============================================================================
# SENTRY (optional)
# ==============================================================================

SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
